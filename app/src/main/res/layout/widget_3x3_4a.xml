<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/widget_background_bitmap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/widget_month_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="2026年5月"
                android:textColor="#1A1A1A"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/widget_create_button"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@android:color/transparent"
                android:contentDescription="@null"
                android:padding="2dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_input_add" />

            <TextView
                android:id="@+id/widget_month_next"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/widget_create_button"
                android:gravity="center"
                android:text="›"
                android:textColor="#9E9E9E"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/widget_month_prev"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@id/widget_month_next"
                android:gravity="center"
                android:text="‹"
                android:textColor="#9E9E9E"
                android:textSize="16sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/widget_week_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="一 二 三 四 五 六 日"
            android:textColor="#9E9E9E"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_calendar_grid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingExtra="2dp"
            android:paddingTop="4dp"
            android:textColor="#1A1A1A"
            android:textSize="9sp"
            android:typeface="monospace" />

        <TextView
            android:id="@+id/widget_section_tasks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="今日任务"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/widget_task_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:scrollbars="none" />

            <TextView
                android:id="@+id/widget_task_list_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="暂无任务"
                android:textColor="#9E9E9E"
                android:textSize="11sp"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/widget_daily_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:paddingTop="4dp"
            android:text="今日一句：心有光芒，步履铿锵"
            android:textColor="#9E9E9E"
            android:textSize="11sp" />
    </LinearLayout>
</FrameLayout>
