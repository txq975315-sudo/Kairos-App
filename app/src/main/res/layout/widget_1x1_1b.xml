<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/widget_background_bitmap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="6dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_1b_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="12"
                android:textColor="#1A1A1A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_1b_weekday"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="星期二"
                android:textColor="#757575"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_1b_task_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:includeFontPadding="false"
                android:text="0/0"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/widget_create_button"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_marginStart="2dp"
                android:background="@android:color/transparent"
                android:contentDescription="@null"
                android:padding="1dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_input_add" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_todo_row_0"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:minHeight="22dp"
            android:orientation="horizontal"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_todo_0_mark"
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="○"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_todo_0_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#1A1A1A"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_todo_row_1"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:minHeight="22dp"
            android:orientation="horizontal"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_todo_1_mark"
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="○"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_todo_1_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#1A1A1A"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_todo_row_2"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:minHeight="22dp"
            android:orientation="horizontal"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_todo_2_mark"
                android:layout_width="16dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="○"
                android:textColor="#9E9E9E"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_todo_2_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="#1A1A1A"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_daily_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:gravity="center_horizontal|top"
            android:lineSpacingExtra="-1dp"
            android:lineSpacingMultiplier="0.92"
            android:maxLines="2"
            android:text=""
            android:textColor="#9E9E9E"
            android:textSize="10sp" />
    </LinearLayout>
</FrameLayout>
