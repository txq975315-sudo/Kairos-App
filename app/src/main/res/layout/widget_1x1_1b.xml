<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/widget_background_bitmap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingTop="6dp"
            android:paddingEnd="28dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="05-06"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="2dp">

                    <ProgressBar
                        android:id="@+id/widget_1b_header_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/widget_progress_drawable"
                        android:rotation="-90" />

                    <TextView
                        android:id="@+id/widget_1b_header_progress_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="0/0"
                        android:textColor="#1A1A1A"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </FrameLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_todo_row_0"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:minHeight="22dp"
                android:orientation="horizontal"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_todo_0_mark"
                    android:layout_width="16dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="○"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_todo_0_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#1A1A1A"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_todo_row_1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:minHeight="22dp"
                android:orientation="horizontal"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_todo_1_mark"
                    android:layout_width="16dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="○"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_todo_1_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#1A1A1A"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_todo_row_2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:minHeight="22dp"
                android:orientation="horizontal"
                android:paddingTop="1dp"
                android:paddingBottom="1dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/widget_todo_2_mark"
                    android:layout_width="16dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="○"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/widget_todo_2_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:textColor="#1A1A1A"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_daily_quote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:gravity="center_horizontal|top"
                android:lineSpacingExtra="-1dp"
                android:lineSpacingMultiplier="0.92"
                android:maxLines="2"
                android:text=""
                android:textColor="#9E9E9E"
                android:textSize="10sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/widget_create_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:background="@android:color/transparent"
            android:contentDescription="@null"
            android:padding="2dp"
            android:scaleType="centerInside"
            android:src="@android:drawable/ic_input_add" />
    </FrameLayout>
</FrameLayout>
