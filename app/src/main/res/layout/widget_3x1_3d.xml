<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <ImageView
        android:id="@+id/widget_background_bitmap"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="@null"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="8dp"
        android:paddingBottom="4dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="30dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal|center_vertical"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_wweek_prev"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="‹"
                    android:textColor="#9E9E9E"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/widget_wweek_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:minWidth="100dp"
                    android:paddingHorizontal="6dp"
                    android:text="5/4–5/10"
                    android:textColor="#1A1A1A"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_wweek_next"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="›"
                    android:textColor="#9E9E9E"
                    android:textSize="16sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/widget_create_button"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="end|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="@null"
                android:padding="2dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_input_add" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="1dp"
            android:paddingBottom="0dp">

            <TextView
                android:id="@+id/widget_week_h0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="一"
                android:textColor="#9E9E9E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_week_h1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="二"
                android:textColor="#9E9E9E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_week_h2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="三"
                android:textColor="#9E9E9E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_week_h3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="四"
                android:textColor="#9E9E9E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_week_h4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="五"
                android:textColor="#9E9E9E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_week_h5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="六"
                android:textColor="#9E9E9E"
                android:textSize="9sp" />

            <TextView
                android:id="@+id/widget_week_h6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="日"
                android:textColor="#9E9E9E"
                android:textSize="9sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="0dp"
            android:paddingBottom="2dp">

            <TextView
                android:id="@+id/widget_wweek_dom0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="5"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wweek_dom1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="6"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wweek_dom2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="7"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wweek_dom3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="8"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wweek_dom4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="9"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wweek_dom5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="10"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_wweek_dom6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:text="11"
                android:textColor="#1A1A1A"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <ListView
                android:id="@+id/widget_3x1_week_task_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:listSelector="@android:color/transparent"
                android:paddingBottom="36dp"
                android:scrollbars="vertical" />

            <TextView
                android:id="@+id/widget_3x1_week_task_list_empty"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingBottom="36dp"
                android:text="—"
                android:textColor="#BDBDBD"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/widget_daily_quote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:background="#1AFFFFFF"
                android:ellipsize="end"
                android:gravity="center_horizontal"
                android:maxLines="2"
                android:minHeight="32dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="6dp"
                android:text=""
                android:textAlignment="center"
                android:textColor="#9E9E9E"
                android:textSize="10sp" />
        </FrameLayout>
    </LinearLayout>
</FrameLayout>
